"""High-level turn engine scaffold for the local-first agent runtime."""

from __future__ import annotations

from dataclasses import dataclass, field
from uuid import uuid4

from .audit import AuditTrail
from .context import RuntimeContext
from .messages import Message, TokenUsage, make_text_block
from .permissions import DenialTrackingState, PermissionEngine
from .session import Session
from .scheduler import (
    ScheduledToolCall,
    build_schedule_plan,
    execute_schedule_plan,
)


@dataclass(frozen=True)
class TurnSummary:
    """Summary of a completed or interrupted turn."""

    assistant_messages: list[Message] = field(default_factory=list)
    tool_messages: list[Message] = field(default_factory=list)
    iterations: int = 0
    usage: TokenUsage = field(default_factory=TokenUsage)
    permission_denials: list[str] = field(default_factory=list)
    stop_reason: str = "completed"


@dataclass
class AgentEngine:
    """Coordinates session state, tool execution, and turn summaries."""

    session: Session
    context: RuntimeContext
    audit: AuditTrail = field(default_factory=AuditTrail)
    permission_engine: PermissionEngine = field(default_factory=PermissionEngine)

    def submit_user_turn(self, prompt: str) -> TurnSummary:
        """Run a single minimal local turn.

        Current behavior is intentionally tiny:
        - append the user message
        - if prompt starts with ``use echo tool:``, build one tool call
        - validate, permission-check, and execute through the scheduler path
        - append tool results plus a final assistant text reply
        """
        self.context.messages = self.session.messages
        self.context.audit_state = self.audit

        self.session.append_user_text(prompt)

        if not prompt.startswith("use echo tool:"):
            assistant = self.session.append_assistant_text(
                "No demo tool triggered."
            )
            return TurnSummary(
                assistant_messages=[assistant],
                tool_messages=[],
                iterations=1,
                usage=self.audit.usage,
                permission_denials=[],
                stop_reason="completed",
            )

        echo_text = prompt.split(":", 1)[1].strip()
        return self._submit_demo_echo_turn(echo_text)

    def _submit_demo_echo_turn(self, echo_text: str) -> TurnSummary:
        """Run the minimal tool execution path for the EchoTool demo."""
        tool = self.context.tool_registry.require("echo")
        tool_input = {"text": echo_text}
        tool_use_id = uuid4().hex

        validation = tool.validate_input(tool_input, self.context)
        if not validation.result:
            assistant = self.session.append_assistant_text(
                f"Echo tool validation failed: {validation.message}"
            )
            return TurnSummary(
                assistant_messages=[assistant],
                tool_messages=[],
                iterations=1,
                usage=self.audit.usage,
                permission_denials=[],
                stop_reason="validation_failed",
            )

        assistant_tool_use = self.session.append_assistant_tool_use(
            tool_use_id=tool_use_id,
            tool_name=tool.name,
            input_data=tool_input,
        )

        tool_permission = tool.check_permissions(tool_input, self.context)
        permission_decision = self.permission_engine.evaluate(
            tool_name=tool.name,
            input_data=tool_input,
            permission_context=self.context.permission_context,
            prompter=self.context.approval_callback,
            denial_tracking=DenialTrackingState(),
        )
        if tool_permission is not None and getattr(tool_permission, "behavior", None) == "deny":
            permission_decision = tool_permission

        if permission_decision.behavior != "allow":
            denial_text = permission_decision.reason
            tool_message = self.session.append_tool_result(
                tool_use_id=tool_use_id,
                tool_name=tool.name,
                output=denial_text,
                is_error=True,
            )
            assistant_final = self.session.append_assistant_text(
                f"Tool call denied: {denial_text}"
            )
            return TurnSummary(
                assistant_messages=[assistant_tool_use, assistant_final],
                tool_messages=[tool_message],
                iterations=1,
                usage=self.audit.usage,
                permission_denials=[denial_text],
                stop_reason="permission_denied",
            )

        scheduled_call = ScheduledToolCall(
            tool_name=tool.name,
            tool_input=tool_input,
            tool_use_id=tool_use_id,
            is_concurrency_safe=tool.is_concurrency_safe(tool_input),
        )
        plan = build_schedule_plan([scheduled_call])
        self.context.in_progress_tool_ids.add(tool_use_id)
        execution_results = execute_schedule_plan(
            plan=plan,
            tool_lookup={tool_use_id: tool},
            context=self.context,
        )
        self.context.in_progress_tool_ids.discard(tool_use_id)

        tool_messages: list[Message] = []
        assistant_messages = [assistant_tool_use]
        for execution_result in execution_results:
            tool_block = execution_result.tool.map_result_to_message(
                execution_result.result,
                execution_result.scheduled_call.tool_use_id,
            )
            tool_messages.append(
                self.session.append(
                    Message(
                        id=uuid4().hex,
                        role="tool",
                        blocks=[tool_block],
                    )
                )
            )

        final_text = f"EchoTool returned: {echo_text}"
        assistant_final = self.session.append_assistant_text(final_text)
        assistant_messages.append(assistant_final)

        return TurnSummary(
            assistant_messages=assistant_messages,
            tool_messages=tool_messages,
            iterations=1,
            usage=self.audit.usage,
            permission_denials=[],
            stop_reason="completed",
        )
