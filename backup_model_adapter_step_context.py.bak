"""Runtime context passed to tools during execution."""

from __future__ import annotations

from dataclasses import dataclass, field
from typing import TYPE_CHECKING, Any, Callable

from .audit import AuditTrail
from .file_state import FileStateStore
from .messages import Message
from .permissions.models import PermissionContext

if TYPE_CHECKING:
    from .tools.registry import ToolRegistry


StateUpdater = Callable[[dict[str, Any]], dict[str, Any]]


def _make_tool_registry() -> ToolRegistry:
    """Create a tool registry without introducing import cycles."""
    from .tools.registry import ToolRegistry

    return ToolRegistry()


@dataclass
class RuntimeContext:
    """Mutable context shared across a turn.

    Phase 1 only establishes the core fields and wiring required for later
    runtime work. Callbacks remain optional.
    """

    tool_registry: ToolRegistry = field(default_factory=_make_tool_registry)
    messages: list[Message] = field(default_factory=list)
    read_file_state: FileStateStore = field(default_factory=FileStateStore)
    in_progress_tool_ids: set[str] = field(default_factory=set)
    permission_context: PermissionContext = field(default_factory=PermissionContext)
    audit_state: AuditTrail | None = field(default_factory=AuditTrail)
    state_store: dict[str, Any] = field(default_factory=dict)
    approval_callback: Callable[..., Any] | None = None
    progress_callback: Callable[..., Any] | None = None

    def get_state(self) -> dict[str, Any]:
        """Return mutable runtime state."""
        return self.state_store

    def set_state(self, updater: StateUpdater) -> None:
        """Apply an update to the mutable runtime state."""
        self.state_store = updater(self.state_store)
