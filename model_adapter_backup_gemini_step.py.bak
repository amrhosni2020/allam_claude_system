"""Model adapter contracts and a local fake model client."""

from __future__ import annotations

from dataclasses import dataclass, field
from typing import Any, Protocol
from uuid import uuid4

from .messages import Message


@dataclass(frozen=True)
class ModelToolCall:
    """A structured tool call returned by a model adapter."""

    id: str
    name: str
    input_data: dict[str, Any]


@dataclass(frozen=True)
class ModelResponse:
    """A model response containing assistant text and optional tool calls."""

    assistant_text: str | None = None
    tool_calls: list[ModelToolCall] = field(default_factory=list)


class ModelClient(Protocol):
    """Protocol for model clients used by the engine."""

    def next_response(self, messages: list[Message]) -> ModelResponse:
        """Return the next assistant response for the current transcript."""
        ...


def _first_text(message: Message) -> str | None:
    """Extract the first text block from a message if present."""
    for block in message.blocks:
        if block.type == "text":
            text = block.data.get("text")
            if isinstance(text, str):
                return text
    return None


@dataclass
class FakeModelClient:
    """Local fake model client for deterministic runtime testing.

    Behavior:
    - if the latest user message asks to echo text, request the ``echo`` tool
    - if the latest user message asks to read a file, request the ``file_read`` tool
    - after a tool result arrives, produce the final assistant text
    - otherwise produce a simple plain-text assistant response
    """

    def next_response(self, messages: list[Message]) -> ModelResponse:
        """Produce the next deterministic model response."""
        if not messages:
            return ModelResponse(assistant_text="No messages provided.")

        last_message = messages[-1]

        if last_message.role == "tool":
            block = last_message.blocks[0]
            tool_name = block.data.get("tool_name")
            output = block.data.get("output")
            if block.data.get("is_error") is True:
                return ModelResponse(
                    assistant_text=f"I could not complete the tool request: {output}"
                )
            if tool_name == "file_read" and isinstance(output, dict):
                path = output.get("path", "unknown")
                content = output.get("content", "")
                line_count = len(str(content).splitlines())
                return ModelResponse(
                    assistant_text=f"Read {path} successfully. The file has {line_count} line(s)."
                )
            return ModelResponse(assistant_text=f"EchoTool returned: {output}")

        if last_message.role == "user":
            text = _first_text(last_message) or ""
            normalized = text.strip()
            lower = normalized.lower()

            echo_payload: str | None = None
            file_payload: str | None = None
            if lower.startswith("echo:"):
                echo_payload = normalized.split(":", 1)[1].strip()
            elif "echo:" in lower:
                echo_payload = normalized[lower.index("echo:") + len("echo:") :].strip()
            elif lower.startswith("read file:"):
                file_payload = normalized.split(":", 1)[1].strip()
            elif "read file:" in lower:
                file_payload = normalized[lower.index("read file:") + len("read file:") :].strip()

            if echo_payload:
                return ModelResponse(
                    tool_calls=[
                        ModelToolCall(
                            id=uuid4().hex,
                            name="echo",
                            input_data={"text": echo_payload},
                        )
                    ]
                )
            if file_payload:
                return ModelResponse(
                    tool_calls=[
                        ModelToolCall(
                            id=uuid4().hex,
                            name="file_read",
                            input_data={"path": file_payload},
                        )
                    ]
                )

            return ModelResponse(assistant_text="No tool needed.")

        return ModelResponse(assistant_text="No tool needed.")
