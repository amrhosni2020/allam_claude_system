"""Model adapter contracts and a local fake model client."""

from __future__ import annotations

import os
from dataclasses import dataclass, field
from typing import Any, Protocol
from uuid import uuid4

from .messages import Message


@dataclass(frozen=True)
class ModelToolCall:
    """A structured tool call returned by a model adapter."""

    id: str
    name: str
    input_data: dict[str, Any]


@dataclass(frozen=True)
class ModelResponse:
    """A model response containing assistant text and optional tool calls."""

    assistant_text: str | None = None
    tool_calls: list[ModelToolCall] = field(default_factory=list)


class ModelClient(Protocol):
    """Protocol for model clients used by the engine."""

    def next_response(self, messages: list[Message]) -> ModelResponse:
        """Return the next assistant response for the current transcript."""
        ...


def _first_text(message: Message) -> str | None:
    """Extract the first text block from a message if present."""
    for block in message.blocks:
        if block.type == "text":
            text = block.data.get("text")
            if isinstance(text, str):
                return text
    return None


def _normalize_function_args(raw_args: Any) -> dict[str, Any]:
    """Normalize SDK function arguments into a plain dictionary."""
    if raw_args is None:
        return {}
    if isinstance(raw_args, dict):
        return dict(raw_args)
    if hasattr(raw_args, "to_dict") and callable(raw_args.to_dict):
        result = raw_args.to_dict()
        if isinstance(result, dict):
            return dict(result)
    if hasattr(raw_args, "items"):
        return {str(key): value for key, value in raw_args.items()}
    return {}


def _parse_function_call(raw_call: Any) -> ModelToolCall | None:
    """Parse a Gemini SDK function-call object into the runtime shape."""
    if raw_call is None:
        return None

    if isinstance(raw_call, dict):
        name = raw_call.get("name")
        raw_args = raw_call.get("args")
        call_id = raw_call.get("id") or uuid4().hex
    else:
        name = getattr(raw_call, "name", None)
        raw_args = getattr(raw_call, "args", None)
        call_id = getattr(raw_call, "id", None) or uuid4().hex

    if not isinstance(name, str) or not name:
        return None

    return ModelToolCall(
        id=str(call_id),
        name=name,
        input_data=_normalize_function_args(raw_args),
    )


def parse_gemini_response_payload(response: Any) -> ModelResponse:
    """Convert a Gemini SDK response into the runtime's model response shape."""
    assistant_text: str | None = None
    raw_text = getattr(response, "text", None)
    if isinstance(raw_text, str) and raw_text.strip():
        assistant_text = raw_text.strip()

    tool_calls: list[ModelToolCall] = []
    raw_function_calls = getattr(response, "function_calls", None) or []
    for raw_call in raw_function_calls:
        parsed_call = _parse_function_call(raw_call)
        if parsed_call is not None:
            tool_calls.append(parsed_call)

    if not tool_calls:
        for candidate in getattr(response, "candidates", []) or []:
            content = getattr(candidate, "content", None)
            for part in getattr(content, "parts", []) or []:
                parsed_call = _parse_function_call(getattr(part, "function_call", None))
                if parsed_call is not None:
                    tool_calls.append(parsed_call)
                if assistant_text is None:
                    part_text = getattr(part, "text", None)
                    if isinstance(part_text, str) and part_text.strip():
                        assistant_text = part_text.strip()

    return ModelResponse(
        assistant_text=assistant_text,
        tool_calls=tool_calls,
    )


def _default_gemini_tool_declarations() -> list[dict[str, Any]]:
    """Return the minimal runtime tool declarations exposed to Gemini."""
    return [
        {
            "name": "echo",
            "description": "Echo text back unchanged.",
            "parameters": {
                "type": "object",
                "properties": {
                    "text": {
                        "type": "string",
                        "description": "The text to echo back.",
                    }
                },
                "required": ["text"],
            },
        },
        {
            "name": "file_read",
            "description": "Read a text file from the current workspace using a relative path.",
            "parameters": {
                "type": "object",
                "properties": {
                    "path": {
                        "type": "string",
                        "description": "A relative path inside the active workspace.",
                    }
                },
                "required": ["path"],
            },
        },
    ]


@dataclass
class GeminiModelClient:
    """Gemini-backed model client using the official Google Gen AI SDK.

    This first version is intentionally conservative:
    - Gemini receives the transcript as rendered text
    - tool declarations are passed as function declarations
    - automatic function calling is disabled
    - any requested tool call still routes through the runtime

    That keeps tool execution under runtime control while remaining easy to test.
    """

    model: str = "gemini-2.5-flash"
    api_key_env: str = "GEMINI_API_KEY"
    tool_declarations: list[dict[str, Any]] = field(
        default_factory=_default_gemini_tool_declarations
    )
    system_instruction: str = (
        "You are a local workspace assistant. "
        "Use available tools when needed, but do not assume tools ran unless tool results appear in the transcript. "
        "When a tool is needed, request a function call instead of pretending you already have the result."
    )

    def next_response(self, messages: list[Message]) -> ModelResponse:
        """Fetch the next response from Gemini and normalize it for the runtime."""
        client, types_module = self._build_sdk_client()
        prompt = self._render_messages_as_prompt(messages)
        config = types_module.GenerateContentConfig(
            system_instruction=self.system_instruction,
            tools=[
                types_module.Tool(
                    function_declarations=[
                        types_module.FunctionDeclaration(**declaration)
                        for declaration in self.tool_declarations
                    ]
                )
            ],
            automatic_function_calling=types_module.AutomaticFunctionCallingConfig(
                disable=True
            ),
        )
        response = client.models.generate_content(
            model=self.model,
            contents=prompt,
            config=config,
        )
        return parse_gemini_response_payload(response)

    def _build_sdk_client(self) -> tuple[Any, Any]:
        """Create the Gemini SDK client lazily so tests stay offline."""
        try:
            from google import genai
            from google.genai import types
        except ImportError as exc:
            raise RuntimeError(
                "The google-genai package is not installed. "
                "Install dependencies before using GeminiModelClient."
            ) from exc

        api_key = os.environ.get(self.api_key_env)
        if not api_key:
            raise RuntimeError(
                f"{self.api_key_env} is not set. Export your Gemini API key first."
            )

        return genai.Client(api_key=api_key), types

    def _render_messages_as_prompt(self, messages: list[Message]) -> str:
        """Render the transcript into a compact Gemini prompt.

        This is a safe intermediate integration layer, not a full native
        function-response conversation protocol yet.
        """
        lines = [
            "Current runtime transcript:",
        ]
        for message in messages:
            lines.append(f"{message.role.upper()}:")
            for block in message.blocks:
                if block.type == "text":
                    lines.append(f"  text: {block.data.get('text', '')}")
                elif block.type == "tool_use":
                    lines.append(
                        f"  tool_use: name={block.data.get('name')} input={block.data.get('input')}"
                    )
                elif block.type == "tool_result":
                    lines.append(
                        "  tool_result: "
                        f"tool_name={block.data.get('tool_name')} "
                        f"output={block.data.get('output')} "
                        f"is_error={block.data.get('is_error')}"
                    )
        lines.append("")
        lines.append(
            "Respond with normal assistant text when no tool is needed. "
            "If a tool is needed, return a function call instead."
        )
        return "\n".join(lines)


@dataclass
class FakeModelClient:
    """Local fake model client for deterministic runtime testing.

    Behavior:
    - if the latest user message asks to echo text, request the ``echo`` tool
    - if the latest user message asks to read a file, request the ``file_read`` tool
    - after a tool result arrives, produce the final assistant text
    - otherwise produce a simple plain-text assistant response
    """

    def next_response(self, messages: list[Message]) -> ModelResponse:
        """Produce the next deterministic model response."""
        if not messages:
            return ModelResponse(assistant_text="No messages provided.")

        last_message = messages[-1]

        if last_message.role == "tool":
            block = last_message.blocks[0]
            tool_name = block.data.get("tool_name")
            output = block.data.get("output")
            if block.data.get("is_error") is True:
                return ModelResponse(
                    assistant_text=f"I could not complete the tool request: {output}"
                )
            if tool_name == "file_read" and isinstance(output, dict):
                path = output.get("path", "unknown")
                content = output.get("content", "")
                line_count = len(str(content).splitlines())
                return ModelResponse(
                    assistant_text=f"Read {path} successfully. The file has {line_count} line(s)."
                )
            return ModelResponse(assistant_text=f"EchoTool returned: {output}")

        if last_message.role == "user":
            text = _first_text(last_message) or ""
            normalized = text.strip()
            lower = normalized.lower()

            echo_payload: str | None = None
            file_payload: str | None = None
            if lower.startswith("echo:"):
                echo_payload = normalized.split(":", 1)[1].strip()
            elif "echo:" in lower:
                echo_payload = normalized[lower.index("echo:") + len("echo:") :].strip()
            elif lower.startswith("read file:"):
                file_payload = normalized.split(":", 1)[1].strip()
            elif "read file:" in lower:
                file_payload = normalized[lower.index("read file:") + len("read file:") :].strip()

            if echo_payload:
                return ModelResponse(
                    tool_calls=[
                        ModelToolCall(
                            id=uuid4().hex,
                            name="echo",
                            input_data={"text": echo_payload},
                        )
                    ]
                )
            if file_payload:
                return ModelResponse(
                    tool_calls=[
                        ModelToolCall(
                            id=uuid4().hex,
                            name="file_read",
                            input_data={"path": file_payload},
                        )
                    ]
                )

            return ModelResponse(assistant_text="No tool needed.")

        return ModelResponse(assistant_text="No tool needed.")
